{
    "name": "superhome-scheduler",
    "version": "0.4.141",
    "private": true,
    "scripts": {
        "dev": "PUBLIC_STAGE=local vite dev",
        "build": "vite build",
        "preview": "vite preview",
        "check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch",
        "lint": "prettier --plugin-search-dir . --check . && eslint .",
        "format": "prettier --plugin-search-dir . --write .",
        "test": "vitest",
        "db_reset": "supabase db reset && supabase gen types typescript --local > src/lib/supabase.types.ts && prettier --plugin-search-dir . --write src/lib/supabase.types.ts"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20260329.1",
        "@faker-js/faker": "^7.6.0",
        "@popperjs/core": "^2.11.8",
        "@sveltejs/adapter-auto": "^7.0.1",
        "@sveltejs/adapter-cloudflare": "^7.2.8",
        "@sveltejs/adapter-node": "^5.5.4",
        "@sveltejs/adapter-vercel": "^6.3.3",
        "@sveltejs/kit": "^2.55.0",
        "@sveltejs/vite-plugin-svelte": "^3.1.2",
        "@types/lodash": "^4.17.24",
        "@types/papaparse": "^5.5.2",
        "@types/web-push": "^3.6.4",
        "@typescript-eslint/eslint-plugin": "^6.21.0",
        "@typescript-eslint/parser": "^6.21.0",
        "autoprefixer": "^10.4.27",
        "esbuild": "^0.27.4",
        "eslint": "8.57.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-svelte": "^3.16.0",
        "flowbite": "^1.8.1",
        "flowbite-svelte": "^0.48.6",
        "postcss": "^8.5.6",
        "postcss-load-config": "^4.0.2",
        "prettier": "2.8.8",
        "prettier-plugin-svelte": "^2.10.1",
        "svelte": "^4.2.20",
        "svelte-check": "^4.4.5",
        "svelte-preprocess": "^6.0.3",
        "tailwindcss": "^3.4.19",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.0",
        "vite": "^5.4.21",
        "vite-plugin-mkcert": "^1.17.10",
        "vitest": "^1.6.1"
    },
    "dependencies": {
        "@sentry/sveltekit": "^10.46.0",
        "@supabase/ssr": "^0.10.0",
        "@supabase/supabase-js": "^2.101.0",
        "daisyui": "^2.52.0",
        "dayjs": "^1.11.20",
        "debounce-fn": "^6.0.0",
        "fetch-retry": "^6.0.0",
        "jszip": "^3.10.1",
        "lodash": "^4.17.23",
        "lru-cache": "^11.2.7",
        "papaparse": "^5.5.3",
        "svelte-french-toast": "^1.2.0",
        "svelte-gestures": "^1.5.2",
        "web-push": "^3.6.7"
    },
    "packageManager": "npm@11.10.1",
    "type": "module"
}
